from __future__ import annotations
import numpy as np
import pandas as pd
from pathlib import Path

BASE = Path("/Users/ambakinanti/Desktop/Malta_portfolio")
INTERNAL = BASE / "data_processed" / "internal_proxy"
OUTFILE = INTERNAL / "internal_proxy_burnout_risk_monthly.csv"

def safe_read_csv(path: Path) -> pd.DataFrame:
    if not path.exists():
        raise FileNotFoundError(f"Missing required file: {path}")
    return pd.read_csv(path)

def main():
    integrity = safe_read_csv(INTERNAL / "internal_proxy_roster_integrity_monthly.csv")

    num_cols = [
        "scheduled_hours","booked_hours","idle_hours","break_hours","recovery_gap_hours",
        "overtime_hours","split_shift_days","coverage_gap_days","worked_days","day_off_days",
        "schedule_stability_score_0_100","workload_density_ratio","max_consecutive_workdays",
        "burnout_exposure_days","day_off_regularity_ratio","recovery_adequacy_ratio",
        "overtime_pressure_ratio","roster_integrity_score_0_100"
    ]
    for c in num_cols:
        if c in integrity.columns:
            integrity[c] = pd.to_numeric(integrity[c], errors="coerce").fillna(0)

    df = integrity.copy()

    df["burnout_risk_score_0_100"] = (
        (df["overtime_pressure_ratio"].clip(upper=1.5) / 1.5 * 30)
        + (df["workload_density_ratio"].clip(upper=1.0) * 25)
        + ((df["max_consecutive_workdays"].clip(lower=0, upper=8) / 8.0) * 20)
        + ((1 - df["day_off_regularity_ratio"].clip(upper=1.0)) * 15)
        + ((1 - (df["schedule_stability_score_0_100"] / 100.0).clip(lower=0, upper=1)) * 10)
    ).clip(lower=0, upper=100)

    df["burnout_risk_band"] = pd.cut(
        df["burnout_risk_score_0_100"],
        bins=[-np.inf, 25, 45, 65, 80, np.inf],
        labels=["low","guarded","elevated","high","critical"]
    ).astype(str)

    df["burnout_primary_driver"] = np.select(
        [
            df["overtime_pressure_ratio"] >= 1.0,
            df["workload_density_ratio"] >= 0.90,
            df["max_consecutive_workdays"] >= 7,
            df["day_off_regularity_ratio"] < 0.70,
        ],
        [
            "overtime_accumulation",
            "dense_booking_load",
            "consecutive_workdays",
            "dayoff_instability",
        ],
        default="mixed_moderate_pressure"
    )

    df["managerial_action_hint"] = np.select(
        [
            df["burnout_risk_score_0_100"] >= 80,
            df["burnout_risk_score_0_100"] >= 65,
            df["burnout_risk_score_0_100"] >= 45,
        ],
        [
            "Immediate roster reset, protect recovery time, and rebalance therapist load.",
            "Reduce overtime exposure and smooth schedule concentration before service quality weakens.",
            "Monitor workload density and preserve day-off consistency.",
        ],
        default="Routine monitoring sufficient; keep sustainable productivity discipline."
    )

    keep = [
        "period_month",
        "outlet_id",
        "therapist_id",
        "roster_integrity_score_0_100",
        "roster_integrity_band",
        "burnout_risk_score_0_100",
        "burnout_risk_band",
        "burnout_primary_driver",
        "managerial_action_hint",
        "overtime_hours",
        "workload_density_ratio",
        "max_consecutive_workdays",
        "day_off_regularity_ratio",
        "schedule_stability_score_0_100",
        "burnout_exposure_days",
    ]
    df = df[keep].sort_values(["period_month", "outlet_id", "therapist_id"]).reset_index(drop=True)
    df.to_csv(OUTFILE, index=False)

    print(f"[OK] saved: {OUTFILE}")
    print(f"[OK] rows: {len(df)}")
    print(df.head(10).to_string(index=False))

if __name__ == "__main__":
    main()
