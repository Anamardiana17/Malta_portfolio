from __future__ import annotations
import numpy as np
import pandas as pd
from pathlib import Path

BASE = Path("/Users/ambakinanti/Desktop/Malta_portfolio")
INTERNAL = BASE / "data_processed" / "internal_proxy"
REFERENCE = BASE / "data_processed" / "reference"

OUTFILE = INTERNAL / "internal_proxy_roster_schedule.csv"

def safe_read_csv(path: Path) -> pd.DataFrame:
    if not path.exists():
        raise FileNotFoundError(f"Missing required file: {path}")
    return pd.read_csv(path)

def normalize_cols(df: pd.DataFrame) -> pd.DataFrame:
    df.columns = [c.strip() for c in df.columns]
    return df

def get_col(df: pd.DataFrame, candidates: list[str], required: bool = True, default=None):
    for c in candidates:
        if c in df.columns:
            return c
    if required:
        raise KeyError(f"Missing required column. Tried: {candidates}")
    return default

def load_policy() -> dict:
    pol = safe_read_csv(REFERENCE / "roster_policy_reference.csv")
    pol = normalize_cols(pol)
    out = {}
    for _, r in pol.iterrows():
        out[str(r["policy_title"]).strip()] = float(r["parameter_value"])
    return out

def main():
    policy = load_policy()

    treatment = normalize_cols(safe_read_csv(INTERNAL / "internal_proxy_treatment_kpi.csv"))
    therapist = normalize_cols(safe_read_csv(INTERNAL / "internal_proxy_therapist_kpi.csv"))
    capacity = normalize_cols(safe_read_csv(INTERNAL / "outlet_capacity_proxy.csv"))
    demand = normalize_cols(safe_read_csv(INTERNAL / "external_demand_proxy_index.csv"))

    # Resolve join columns
    t_date = get_col(treatment, ["period_start", "period_date", "date"])
    t_outlet = get_col(treatment, ["outlet_id"])
    t_treatment = get_col(treatment, ["treatment_category", "treatment_code", "treatment_name"], required=False)

    th_date = get_col(therapist, ["period_start", "period_date", "date"])
    th_outlet = get_col(therapist, ["outlet_id"])
    th_therapist = get_col(therapist, ["therapist_id"])
    th_booked = get_col(therapist, ["booked_hours", "therapist_hours_sold", "hours_sold"], required=False)
    th_util = get_col(therapist, ["utilization_ratio", "utilization", "utilization_rate"], required=False)
    th_revpath = get_col(therapist, ["revpath", "revpath_ntd_per_therapist_hour", "revpath_eur_per_therapist_hour"], required=False)

    c_date = get_col(capacity, ["period_start", "period_date", "date"])
    c_outlet = get_col(capacity, ["outlet_id"])
    c_cap = get_col(capacity, ["available_capacity_hours", "capacity_hours", "therapist_hours_available"], required=False)

    d_date = get_col(demand, ["period_start", "period_date", "date"])
    d_outlet = get_col(demand, ["outlet_id"], required=False)
    d_index = get_col(demand, ["external_demand_proxy_index", "demand_proxy_index"], required=False)

    therapist[th_date] = pd.to_datetime(therapist[th_date])
    capacity[c_date] = pd.to_datetime(capacity[c_date])
    demand[d_date] = pd.to_datetime(demand[d_date])

    # Start from therapist KPI grain, assumed therapist-period.
    df = therapist.copy()

    # Booked hours base
    if th_booked and th_booked in df.columns:
        df["booked_hours_base"] = pd.to_numeric(df[th_booked], errors="coerce").fillna(0)
    elif th_util:
        util = pd.to_numeric(df[th_util], errors="coerce").fillna(0).clip(lower=0, upper=1)
        df["booked_hours_base"] = util * 120
    else:
        df["booked_hours_base"] = 80.0

    # Demand merge
    demand_small = demand[[d_date] + ([d_outlet] if d_outlet else []) + ([d_index] if d_index else [])].copy()
    demand_small = demand_small.rename(columns={d_date: "period_date"})
    if d_outlet:
        demand_small = demand_small.rename(columns={d_outlet: "outlet_id"})
    if d_index:
        demand_small = demand_small.rename(columns={d_index: "external_demand_proxy_index"})
    else:
        demand_small["external_demand_proxy_index"] = 100.0

    df = df.rename(columns={th_date: "period_date", th_outlet: "outlet_id", th_therapist: "therapist_id"})
    df["period_date"] = pd.to_datetime(df["period_date"])

    if "outlet_id" in demand_small.columns:
        df = df.merge(demand_small, on=["period_date", "outlet_id"], how="left")
    else:
        df = df.merge(demand_small[["period_date", "external_demand_proxy_index"]], on="period_date", how="left")
    df["external_demand_proxy_index"] = pd.to_numeric(df["external_demand_proxy_index"], errors="coerce").fillna(100)

    # Outlet capacity merge
    cap_small = capacity[[c_date, c_outlet] + ([c_cap] if c_cap else [])].copy()
    cap_small = cap_small.rename(columns={c_date: "period_date", c_outlet: "outlet_id"})
    if c_cap:
        cap_small = cap_small.rename(columns={c_cap: "outlet_capacity_hours"})
    else:
        cap_small["outlet_capacity_hours"] = np.nan

    df = df.merge(cap_small, on=["period_date", "outlet_id"], how="left")
    df["outlet_capacity_hours"] = pd.to_numeric(df["outlet_capacity_hours"], errors="coerce")

    # Approximate therapist roster from demand & booked pattern
    demand_factor = (df["external_demand_proxy_index"] / 100.0).clip(lower=0.70, upper=1.30)

    base_shift_hours = policy["standard_shift_hours"]
    base_break_hours = policy["standard_break_hours"]
    productive_factor = policy["productive_capacity_factor"]
    safe_daily = policy["max_safe_daily_scheduled_hours"]
    min_gap = policy["minimum_recovery_gap_hours"]

    df["scheduled_hours"] = (df["booked_hours_base"] / productive_factor) * np.where(
        demand_factor > 1.10, 1.03,
        np.where(demand_factor < 0.92, 0.97, 1.00)
    )
    df["scheduled_hours"] = df["scheduled_hours"].clip(lower=0, upper=230)

    # Normalize to plausible monthly range
    df["scheduled_hours"] = np.where(
        df["scheduled_hours"] < 60,
        60 + (df["scheduled_hours"] * 0.35),
        df["scheduled_hours"]
    )
    df["scheduled_hours"] = df["scheduled_hours"].clip(lower=60, upper=220)

    df["booked_hours"] = df["booked_hours_base"].clip(lower=0)
    df["productive_capacity_hours"] = (df["scheduled_hours"] * productive_factor).clip(lower=0)
    df["idle_hours"] = (df["productive_capacity_hours"] - df["booked_hours"]).clip(lower=0)

    # Workdays estimate
    df["worked_days"] = np.ceil(df["scheduled_hours"] / base_shift_hours).clip(lower=8, upper=27)
    df["day_off_days"] = (30 - df["worked_days"]).clip(lower=2, upper=12)

    # Daily density estimate
    df["workload_density_ratio"] = (df["booked_hours"] / df["productive_capacity_hours"].replace(0, np.nan)).fillna(0).clip(lower=0, upper=1.25)

    # Break / recovery / overtime
    df["break_hours"] = (df["worked_days"] * base_break_hours).clip(lower=0)
    df["recovery_gap_hours"] = np.where(
        df["workload_density_ratio"] >= 0.90, min_gap * 0.75,
        np.where(df["workload_density_ratio"] >= 0.82, min_gap * 0.95, min_gap * 1.15)
    )

    df["avg_daily_scheduled_hours"] = (df["scheduled_hours"] / df["worked_days"]).replace([np.inf, -np.inf], np.nan).fillna(0)
    df["overtime_hours"] = ((df["avg_daily_scheduled_hours"] - safe_daily).clip(lower=0) * df["worked_days"]).clip(lower=0)

    df["split_shift_flag"] = np.where(
        (df["workload_density_ratio"] < 0.55) & (df["scheduled_hours"] > 120), 1,
        np.where((df["workload_density_ratio"] > 0.92) & (df["day_off_days"] <= 5), 1, 0)
    )

    df["coverage_gap_ratio"] = (df["booked_hours"] / df["productive_capacity_hours"].replace(0, np.nan)).fillna(0)
    df["coverage_gap_flag"] = np.where(df["coverage_gap_ratio"] > 1.0, 1, 0)

    df["day_off_flag"] = np.where(df["worked_days"] == 0, 1, 0)
    df["worked_flag"] = np.where(df["worked_days"] > 0, 1, 0)

    # Stability logic
    df["schedule_stability_score_0_100"] = (
        100
        - (df["split_shift_flag"] * 12)
        - np.where(df["overtime_hours"] > 0, np.minimum(20, df["overtime_hours"] * 0.8), 0)
        - np.where(df["day_off_days"] < 4, (4 - df["day_off_days"]) * 5, 0)
        - np.where(df["workload_density_ratio"] > 0.90, (df["workload_density_ratio"] - 0.90) * 80, 0)
    ).clip(lower=20, upper=100)

    # Consecutive days approximation
    df["consecutive_workdays"] = np.where(
        df["day_off_days"] <= 3, 7,
        np.where(df["day_off_days"] <= 5, 6, 4)
    ).astype(int)

    df["burnout_exposure_flag"] = np.where(
        (df["overtime_hours"] >= 8) |
        (df["workload_density_ratio"] >= 0.90) |
        (df["consecutive_workdays"] >= 7),
        1, 0
    )

    keep_cols = [
        "period_date",
        "outlet_id",
        "therapist_id",
        "scheduled_hours",
        "booked_hours",
        "productive_capacity_hours",
        "idle_hours",
        "break_hours",
        "recovery_gap_hours",
        "overtime_hours",
        "split_shift_flag",
        "coverage_gap_flag",
        "day_off_flag",
        "worked_flag",
        "day_off_days",
        "worked_days",
        "schedule_stability_score_0_100",
        "workload_density_ratio",
        "consecutive_workdays",
        "burnout_exposure_flag",
        "external_demand_proxy_index",
    ]

    for col in keep_cols:
        if col not in df.columns:
            df[col] = np.nan

    out = df[keep_cols].copy()
    out = out.sort_values(["period_date", "outlet_id", "therapist_id"]).reset_index(drop=True)
    out.to_csv(OUTFILE, index=False)

    print(f"[OK] saved: {OUTFILE}")
    print(f"[OK] rows: {len(out)}")
    print(out.head(10).to_string(index=False))

if __name__ == "__main__":
    main()
